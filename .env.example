# Скопируй этот файл в .env и заполни значения.
# .env в git не попадёт (он в .gitignore).

# Токен бота от @BotFather (пример: 123456789:AA...)
VITE_TELEGRAM_BOT_TOKEN=

# Куда слать заявки — твой Telegram chat_id (числовой).
# Как узнать: напиши боту @userinfobot, он пришлёт твой id.
# Не забудь один раз нажать Start у своего бота, иначе он не сможет тебе написать.
VITE_TELEGRAM_CHAT_ID=
